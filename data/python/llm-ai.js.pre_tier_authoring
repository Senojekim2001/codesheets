# ── Step 1: Load documents ───────────────────────────
def load_documents(file_path: str) -> str:
    with open(file_path) as f:
        return f.read()

raw_text = load_documents("knowledge_base.md")

# ── Step 2: Chunk documents ──────────────────────────
splitter = RecursiveCharacterTextSplitter(
    chunk_size=500,        # ~500 chars per chunk
    chunk_overlap=50,      # overlap for context continuity
    separators=["\\n\\n", "\\n", ". ", " "],  # split at natural boundaries
)
chunks = splitter.split_text(raw_text)
print(f"Created {len(chunks)} chunks")

# ── Step 3-4: Embed and store ────────────────────────
chroma = chromadb.PersistentClient(path="./rag_db")
collection = chroma.get_or_create_collection("knowledge")

# Batch embed with OpenAI
def embed_texts(texts: list[str]) -> list:
    resp = client.embeddings.create(
        input=texts, model="text-embedding-3-small"
    )
    return [e.embedding for e in resp.data]

# Store chunks with embeddings
batch_size = 100
for i in range(0, len(chunks), batch_size):
    batch = chunks[i:i + batch_size]
    embeddings = embed_texts(batch)
    collection.add(
        ids=[f"chunk_{i+j}" for j in range(len(batch))],
        embeddings=embeddings,
        documents=batch,
    )

# ── Step 5-8: Query pipeline ────────────────────────
def rag_query(question: str, n_results: int = 5) -> str:
    # Embed the question
    query_emb = embed_texts([question])[0]

    # Retrieve relevant chunks
    results = collection.query(
        query_embeddings=[query_emb],
        n_results=n_results,
    )
    context = "\\n\\n---\\n\\n".join(results["documents"][0])

    # Augmented generation
    response = client.chat.completions.create(
        model="gpt-4o",
        messages=[
            {
                "role": "system",
                "content": (
                    "Answer the question based ONLY on the following context. "
                    "If the context doesn't contain the answer, say so.\\n\\n"
                    f"Context:\\n{context}"
                ),
            },
            {"role": "user", "content": question},
        ],
        temperature=0,
    )
    return response.choices[0].message.content


# ── Process hints dynamically ──────────────────────
def validate_args(func: Callable, args: dict[str, Any]) -> bool:
    """Check if args match function hints."""
    hints = get_type_hints(func)
    for name, expected_type in hints.items():
        if name == "return":
            continue
        if name not in args:
            print(f"Missing arg: {name}")
            return False
        value = args[name]
        if not isinstance(value, expected_type):
            print(f"{name} should be {expected_type}, got {type(value)}")

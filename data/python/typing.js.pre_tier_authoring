class Serializable(Protocol):
    def to_json(self) -> str: ...
    def from_json(self, data: str) -> None: ...

class Cacheable(Protocol):
    @property
    def cache_key(self) -> str: ...
    def ttl(self) -> int: ...

# ── Classes satisfy protocols structurally ───────────
class User:
    """No inheritance from Serializable — just has the methods."""
    def __init__(self, name: str):
        self.name = name

    def to_json(self) -> str:
        import json
        return json.dumps({"name": self.name})

    def from_json(self, data: str) -> None:
        import json
        self.name = json.loads(data)["name"]

def save(obj: Serializable) -> None:
    """Accepts ANY object with to_json/from_json methods."""
    print(obj.to_json())

save(User("Alice"))  # OK — User has required methods

# ── Callable protocol (more precise than Callable) ───
class Validator(Protocol):
    def __call__(self, value: str) -> bool: ...

def check_all(value: str, validators: list[Validator]) -> bool:
    return all(v(value) for v in validators)


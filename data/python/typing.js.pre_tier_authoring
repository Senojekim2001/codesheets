def schema_from_hints(cls: type) -> dict[str, str]:
    """Generate JSON schema from class hints."""
    hints = get_type_hints(cls)
    schema = {}
    for name, type_hint in hints.items():
        origin = get_origin(type_hint)
        if origin is list:
            schema[name] = "array"
        elif origin is dict:
            schema[name] = "object"
        elif type_hint is str:
            schema[name] = "string"
        elif type_hint is int:
            schema[name] = "integer"
        elif type_hint is bool:
            schema[name] = "boolean"
        elif origin is Union:
            schema[name] = "union"
        else:
            schema[name] = str(type_hint)
    return schema


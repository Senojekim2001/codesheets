        desc: 'Vocabulary for the different kinds of fake objects used in testing.',
        subtitle: 'Stub / Fake / Spy / Mock — know which to use when',
        signature: 'stub → fixed return | mock → verify calls | spy → wrap real obj',
        descLong: 'Test doubles are objects that stand in for real dependencies. The terms are often used loosely but have distinct meanings: stubs return fixed values, fakes have working implementations, spies record calls without replacing behavior, mocks verify specific interactions were made.',
        code: `# Stub — returns a fixed value, no logic:
class StubEmailService:
    def send(self, to, subject, body):
        return True   # always succeeds, does nothing real
# Fake — working implementation, not production-ready:
class FakeDatabase:
    def __init__(self):
        self._store = {}

    def get(self, key):
        return self._store.get(key)
    def set(self, key, value):
        self._store[key] = value
# Spy — wraps a real object, records calls:
from unittest.mock import MagicMock, patch, call
class SpyEmailService:
    def __init__(self, real_service):
        self._real = real_service
        self.calls = []
        self.calls.append((to, subject))
        return self._real.send(to, subject, body)
# Mock — replaces entirely, verifies interactions:
mock_service = MagicMock()
mock_service.send.return_value = True
# Use it:
send_welcome_email("alice@example.com", mock_service)
# Verify:
mock_service.send.assert_called_once_with(
    "alice@example.com",
    "Welcome!",
    mock_service.send.call_args[0][2],
)
# When to use each:
# stub  → you don't care HOW it's called, just need a return value
# fake  → you need real behavior (in-memory DB for integration tests)
# spy   → you want to verify calls without breaking real behavior
# mock  → you want to verify exact interactions (call count, args)`,

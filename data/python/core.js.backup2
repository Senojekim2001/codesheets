        id: 'pathlib', fn: 'pathlib.Path', desc: 'Object-oriented filesystem path manipulation.',
        category: 'Standard Library', subtitle: 'Cross-platform paths — / operator, read_text, glob, mkdir',
        signature: 'Path("dir") / "file.txt" | path.read_text() | path.glob("*.csv")',
        descLong: 'pathlib.Path is the modern replacement for os.path. It is object-oriented, cross-platform (handles / vs \\ automatically), and far more readable. Use it for all file system operations — file reading, directory creation, globbing.',
        code: `from pathlib import Path
# Build paths with / operator:
p = Path("data") / "input.csv"
p = Path.home() / "Documents" / "report.pdf"
p = Path.cwd() / "output"
# Properties:
p.name       # "input.csv"
p.stem       # "input"
p.suffix     # ".csv"
p.parent     # Path("data")
p.parts      # ("data", "input.csv")
# Test:
p.exists()
p.is_file()
p.is_dir()
p.stat().st_size   # bytes
# Read / write:
text = p.read_text(encoding="utf-8")
p.write_text("hello", encoding="utf-8")
data = p.read_bytes()
p.write_bytes(b"binary")
# Line by line (memory efficient):
with open(p) as f:
    for line in f:
        process(line.rstrip())
# Directory operations:
p.mkdir(parents=True, exist_ok=True)
p.unlink(missing_ok=True)    # delete file
p.rename(new_path)

# Glob:
list(Path(".").glob("*.py"))         # *.py in current dir
list(Path(".").rglob("*.csv"))       # recursive
sorted(Path("data").glob("**/*.json"))`,
        tips: [
          '`Path.home() / "docs" / "file.txt"` is cross-platform — no hardcoded `/` or `\\\\`',
          '`path.read_text()` / `write_text()` for simple files; `open()` context manager for streaming',
          '`path.rglob("*.csv")` recursively finds all CSVs — replaces `os.walk()` for most cases',
          '`exist_ok=True` in `mkdir()` is idempotent — create if absent, no error if present',
        ],
        mistake: 'String concatenation for paths: `path = dir + "/" + filename`. Breaks on Windows where the separator is `\\\\`. Use `Path(dir) / filename`.',
        shorthand: {

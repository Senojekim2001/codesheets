      {
        id: 'tuple', fn: 'tuple', desc: 'Immutable ordered sequence — use for fixed records and dict keys.',
        category: 'Data Types', subtitle: 'Like a list but immutable — hashable when elements are hashable',
        signature: 't = (1, 2, 3) | t = 1, 2, 3 | a, b = b, a',
        descLong: 'Tuples are immutable ordered sequences. They are faster than lists, use less memory, and can be used as dict keys or set members (when all elements are hashable). Parentheses are optional — the comma makes the tuple.',
        code: `from collections import Counter, defaultdict, deque, namedtuple

# Creation — comma makes the tuple, not parens:
t = (1, 2, 3)
t = 1, 2, 3         # same thing
t = (1,)            # single-element — trailing comma required
t = ()              # empty tuple

# Access (same as list):
t[0]                # 1
t[-1]               # 3
t[1:3]              # (2, 3)

# Unpacking:
a, b, c  = (1, 2, 3)
first, *rest = (1, 2, 3, 4)   # rest = [2,3,4] — a list!

# Swap without temp variable:
a, b = b, a

# Tuple as dict key (all elements must be hashable):
d = {}
d[(0, 0)] = "origin"
d[(1, 0)] = "right"

# Tuple unpacking in loops:
pairs = [(1,"a"), (2,"b"), (3,"c")]
for num, letter in pairs:
    print(num, letter)

# Named tuple — readable field access:
from collections import namedtuple
Point = namedtuple("Point", ["x", "y"])
p = Point(3, 4)
p.x, p.y          # 3, 4
p._asdict()       # {'x': 3, 'y': 4}
p._replace(x=10)  # Point(x=10, y=4) — new instance`,
        tips: [
          'A single-element tuple needs a trailing comma: `(1,)` not `(1)` — the latter is just parentheses',
          'Tuples can be dict keys or set members; lists cannot — use tuples when hashability matters',
          '`a, b = b, a` is a tuple swap — no temporary variable needed',
          'Use `namedtuple` when tuple fields need descriptive names — cheaper than a full class',
        ],
        mistake: '`t = (1)` is the integer `1`, not a tuple. The comma makes the tuple: `t = (1,)` or `t = 1,`.',
        shorthand: {
          verbose: `result = []
for x in items:
    result.append(x * 2)`,
          concise: `result = [x * 2 for x in items]`
        }
      },
      {
        id: 'namedtuple', fn: 'namedtuple', desc: 'Lightweight immutable record type with named fields.',
        category: 'Data Types', subtitle: 'Tuple with attribute access — no class boilerplate needed',
        signature: 'Point = namedtuple("Point", ["x", "y"]) | typing.NamedTuple',
        descLong: 'collections.namedtuple creates a tuple subclass with named fields. Lighter than a class, more readable than a plain tuple. The modern alternative is typing.NamedTuple which supports type hints and default values.',
        code: `from collections import Counter, defaultdict, deque, namedtuple
# Classic namedtuple:
Point = namedtuple('Point', ['x', 'y'])
p.x            # 3
p.y            # 4
p[0]           # 3 — still works as a tuple
p._asdict()    # {'x': 3, 'y': 4}
p._replace(x=10)   # Point(x=10, y=4) — new instance
# Unpack like a tuple:
x, y = p
# Use as dict key (hashable):
distances = {Point(0,0): 0, Point(1,0): 1}
# With defaults (Python 3.6.1+):
Point3D = namedtuple('Point3D', ['x', 'y', 'z'], defaults=[0])
Point3D(1, 2)      # Point3D(x=1, y=2, z=0)
# Modern syntax — typing.NamedTuple (preferred):
from typing import NamedTuple
class Employee(NamedTuple):
    name:   str
    dept:   str
    salary: float = 0.0

e = Employee('Alice', 'Engineering', 95000)
e.name     # 'Alice'
e._asdict()`,
        tips: [
          'Use typing.NamedTuple class syntax for new code — supports type hints and default values',
          'namedtuple is immutable — use _replace() to create a modified copy',
          'Lighter than a dataclass when you only need field access and no methods',
          '_asdict() converts to a dict — useful for JSON serialization',
        ],
        mistake: 'Using a plain tuple (x, y) where namedtuple would be clearer. point[0] is cryptic; point.x is self-documenting. The overhead is negligible.',
        shorthand: {
          verbose: `from collections import Counter, defaultdict, deque, namedtuple
from collections import namedtuple
Point = namedtuple('Point', ['x', 'y'])
p = Point(3, 4)`,
          concise: `e._asdict()`
        }

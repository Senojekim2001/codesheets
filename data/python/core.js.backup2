        id: 'argparse-cli', fn: 'argparse (Command-Line Arguments)', desc: 'Parse and validate CLI arguments with help messages.',
        category: 'I/O', subtitle: 'Professional CLI with argument validation',
        signature: 'import argparse\nparser = ArgumentParser()\nparser.add_argument(...)\nargs = parser.parse_args()',
        descLong: 'argparse provides CLI argument parsing with automatic help, type conversion, and validation. Better than sys.argv parsing manually.',
        code: `import argparse
# Basic script argument
parser = argparse.ArgumentParser(
    description='Analyze sales data and generate reports'
# Positional arguments (required)
parser.add_argument('input_file', help='Input CSV file')
parser.add_argument('output_file', help='Output report file')
# Optional arguments (flags)
parser.add_argument(
    '--format', '-f',
    choices=['pdf', 'html', 'txt'],
    default='pdf',
    help='Output format (default: pdf)'
    '--verbose', '-v',
    action='store_true',
    help='Enable verbose output'
    '--year', '-y',
    type=int,
    default=2026,
    help='Year to analyze (default: 2026)'
args = parser.parse_args()
# Access arguments as attributes
print(f'Input: {args.input_file}')
print(f'Output: {args.output_file}')
print(f'Format: {args.format}')
print(f'Verbose: {args.verbose}')
print(f'Year: {args.year}')
# Usage:
# python script.py sales.csv report.pdf --format html -v --year 2025
# Advanced: Multiple values
parser2 = argparse.ArgumentParser()
parser2.add_argument(
    'files',
    nargs='+',  # One or more files
    help='Files to process'

    '--exclude',
    nargs='*',  # Zero or more
    default=[],
    help='Files to exclude'
)
args2 = parser2.parse_args()
# python script.py file1.py file2.py file3.py --exclude test.py
# Validation with custom type
def positive_int(value):
    ivalue = int(value)
    if ivalue < 0:
        raise argparse.ArgumentTypeError(f'{value} is invalid (must be positive)')
    return ivalue
parser3 = argparse.ArgumentParser()
parser3.add_argument('count', type=positive_int, help='Number of items')
# Mutually exclusive group
parser4 = argparse.ArgumentParser()
group = parser4.add_mutually_exclusive_group(required=True)
group.add_argument('--add', action='store_true', help='Add item')
group.add_argument('--remove', action='store_true', help='Remove item')
# Subcommands
parser5 = argparse.ArgumentParser(description='Database management tool')
subparsers = parser5.add_subparsers(dest='command', help='Command')
# init subcommand
init_parser = subparsers.add_parser('init', help='Initialize database')
init_parser.add_argument('--path', required=True, help='Database path')
# backup subcommand
backup_parser = subparsers.add_parser('backup', help='Backup database')
backup_parser.add_argument('--destination', required=True, help='Backup path')
backup_parser.add_argument('--compress', action='store_true', help='Compress backup')
# python script.py init --path /data/mydb.sqlite
# python script.py backup --destination /backup/mydb.backup --compress
args5 = parser5.parse_args()
if args5.command == 'init':
    print(f'Initializing at {args5.path}')
elif args5.command == 'backup':
    print(f'Backing up to {args5.destination}')
# Environment variable fallback
import os
parser6 = argparse.ArgumentParser()
parser6.add_argument(
    '--api-key',
    default=os.getenv('API_KEY'),
    help='API key (default from API_KEY env var)'
# Auto help (always generated)
# python script.py --help
# usage: script.py [-h] [--format {pdf,html,txt}] [-v] [-y YEAR] input_file output_file
#
# Analyze sales data and generate reports
# positional arguments:
#   input_file          Input CSV file
#   output_file         Output report file
# optional arguments:
#   -h, --help          show this help message and exit
#   --format, -f        Output format (default: pdf)
#   ...`,
        tips: [
          'nargs="+" for at least one, "*" for zero or more, "?" for optional argument',
          'action="store_true" for boolean flags (no value needed)',
          'required=True on add_argument for mandatory options',
          'Custom type functions validate inputs (e.g., positive_int)',
        ],
        mistake: 'Using sys.argv directly instead of argparse. argparse provides validation, help, and better defaults.',
        shorthand: {
          verbose: `result = []
for x in items:
    if x > 0:
        result.append(x)`,
          concise: `result = [x for x in items if x > 0]`
        }
      },
      {
        id: 'typing-module-hints', fn: 'typing Module (Type Hints)', desc: 'Add type annotations for better IDE support and static checking.',
        category: 'Type System', subtitle: 'Optional runtime type hints for clarity and tooling',
        signature: 'from typing import List, Dict, Optional, Callable, Union\ndef func(x: int) -> str: ...',
        descLong: 'Type hints document expected types and enable IDE autocompletion and static checkers (mypy). Python enforces at runtime but hints help tooling and developers.',
        code: `import pandas as pd
from typing import Optional, Union, List, Dict, Callable, Tuple, Any
from typing import List, Dict, Optional, Callable, Union, Tuple, Any, TypeVar, Generic
# Basic type hints
def greet(name: str) -> str:
    return f'Hello {name}'
def add(a: int, b: int) -> int:
    return a + b
# Collection types
def process_items(items: List[str]) -> None:
    for item in items:
        print(item)
def get_config() -> Dict[str, Any]:
    return {'host': 'localhost', 'port': 8080}
# Optional (can be None)
def get_user(user_id: int) -> Optional[Dict[str, str]]:
    if user_id > 0:
        return {'id': user_id, 'name': 'Alice'}
    return None  # Can return None
# Union (multiple types)
def process(data: Union[str, int, List[str]]) -> None:
    if isinstance(data, str):
        print(data)
    elif isinstance(data, int):
        print(data * 2)
# Tuple (fixed-size, typed)
def get_coordinates() -> Tuple[float, float]:
    return (1.5, 2.5)
def unpack() -> Tuple[str, int, bool]:
    return ('Alice', 30, True)
# Callable (function type)
def apply_func(x: int, func: Callable[[int], int]) -> int:
    return func(x)
square = lambda x: x ** 2
result = apply_func(5, square)  # result = 25
# TypeVar (generic type)
T = TypeVar('T')
def first(items: List[T]) -> T:
    return items[0]
# Can be any type, but consistent
num = first([1, 2, 3])     # T = int
name = first(['a', 'b'])   # T = str
# Generic class
class Container(Generic[T]):
    def __init__(self, value: T):
        self.value = value
    def get(self) -> T:
        return self.value
# Usage
int_container = Container[int](42)
str_container = Container[str]('hello')
# Class annotations
class Person:
    name: str
    age: int
    def __init__(self, name: str, age: int) -> None:
        self.name = name
        self.age = age
    def display(self) -> str:
        return f'{self.name}, {self.age}'
# Dataclass with type hints
from dataclasses import dataclass
@dataclass
class Point:
    x: float
    y: float
    def distance_from_origin(self) -> float:
        return (self.x ** 2 + self.y ** 2) ** 0.5
# Default arguments
def greet_default(name: str = 'Guest') -> str:
# Variable annotations
numbers: List[int] = [1, 2, 3, 4, 5]
config: Dict[str, Any] = {'debug': True, 'timeout': 30}
user_name: Optional[str] = None

# Literal (specific values)
from typing import Literal
def set_level(level: Literal['DEBUG', 'INFO', 'WARNING', 'ERROR']) -> None:
    print(f'Level: {level}')
set_level('INFO')
# set_level('UNKNOWN')  # Type checker warns
# Type checking with mypy (external tool)
# mypy script.py   # Check types without running
# Forward reference (class referencing itself)
class Node:
    def __init__(self, value: int, next: Optional['Node'] = None):
        self.next = next
# Any (opt-out of type checking)
def process_any(data: Any) -> Any:
    return data  # Can be anything
# TypedDict (dictionary structure)
from typing import TypedDict
class UserDict(TypedDict):
    id: int
    email: str
def get_user() -> UserDict:
    return {'id': 1, 'name': 'Alice', 'email': 'alice@example.com'}`,
          tips: [
          'Type hints don\'t enforce at runtime — use mypy (static checker) for validation',
          'Optional[T] is equivalent to Union[T, None]',
          'TypeVar for generic functions — type must be consistent within function',
          'IDE uses hints for autocompletion — huge productivity boost',
        ],
        mistake: 'Thinking type hints enforce runtime constraints. They don\'t — they\'re for tooling. Use isinstance() checks for runtime validation.',
        shorthand: {
          verbose: `result = []
for x in items:
    if x > 0:
        result.append(x)`,
          concise: `result = [x for x in items if x > 0]`
        }
      },
    ],
  },
]


      {
        id: 'functools-partial-cache', fn: 'functools (partial, lru_cache, reduce)', desc: 'Functional programming utilities: function wrapping, caching, reduction.',
        category: 'Functions', subtitle: 'Partial application, memoization, and functional composition',
        signature: 'from functools import partial, lru_cache, reduce, wraps',
        descLong: 'functools provides higher-order functions for composition and optimization. partial pre-fills function arguments, lru_cache memoizes results, reduce folds a function over an iterable, wraps preserves function metadata in decorators.',
        code: `from functools import partial, lru_cache, reduce, wraps
from operator import mul, add
# partial: Create specialized versions of functions
def multiply(a, b):
    return a * b
double = partial(multiply, 2)  # Pre-fill first arg
triple = partial(multiply, 3)
print(double(5))   # 10 (2 * 5)
print(triple(5))   # 15 (3 * 5)
# Useful with built-in functions
def add_prefix(prefix, text):
    return prefix + text
add_hello = partial(add_prefix, 'Hello ')
print(add_hello('World'))  # 'Hello World'

# Pre-fill multiple arguments
def power(base, exponent):
    return base ** exponent
square = partial(power, exponent=2)
cube = partial(power, exponent=3)
print(square(5))  # 25
print(cube(5))    # 125
# lru_cache: Memoize function results
@lru_cache(maxsize=128)  # Cache up to 128 results
def fibonacci(n):
    if n < 2:
        return n
    return fibonacci(n - 1) + fibonacci(n - 2)
print(fibonacci(10))  # Fast (cached results)
print(fibonacci(10))  # Instant (from cache)
# Cache info
print(fibonacci.cache_info())  # CacheInfo(hits=8, misses=11, ...)
fibonacci.cache_clear()        # Clear cache
# Expensive computation example
@lru_cache(maxsize=32)
def fetch_data(url):
    print(f'Fetching {url}...')
    # Simulate slow API call
    import time
    time.sleep(1)
    return f'Data from {url}'
print(fetch_data('http://api.example.com'))  # Fetches
print(fetch_data('http://api.example.com'))  # Instant (cached)
# reduce: Fold (accumulate) a function over items
numbers = [1, 2, 3, 4, 5]
total = reduce(add, numbers)
print(total)  # 15 (1+2+3+4+5)
product = reduce(mul, numbers)
print(product)  # 120 (1*2*3*4*5)
# With custom function
def combine(a, b):
    return f'{a},{b}'
result = reduce(combine, ['a', 'b', 'c', 'd'])
print(result)  # 'a,b,c,d'
# reduce with initializer
total = reduce(add, numbers, 100)  # Start with 100
print(total)  # 115 (100 + sum of numbers)
# wraps: Preserve original function metadata in decorators
def my_decorator(func):
    @wraps(func)  # Copy __name__, __doc__, __module__ etc.
    def wrapper(*args, **kwargs):
        print(f'Calling {func.__name__}')
        return func(*args, **kwargs)
    return wrapper
@my_decorator
def greet(name):
    '''Greet a person.'''
    return f'Hello {name}'
print(greet.__name__)  # 'greet' (not 'wrapper')
print(greet.__doc__)   # 'Greet a person.'
# Composition: chain partial and reduce
def apply_operations(value, *operations):
    return reduce(lambda x, op: op(x), operations, value)
double_fn = partial(multiply, 2)
add_ten = partial(add, 10)
result = apply_operations(5, double_fn, add_ten)
print(result)  # 20 (5 * 2 + 10)
# Cache with custom key (unhashable args)
@lru_cache(maxsize=128)
def process_tuple(data_tuple):
    return sum(data_tuple)
print(process_tuple((1, 2, 3)))  # 6 (cached)
# process_tuple([1, 2, 3])  # TypeError: unhashable type (use tuple)
# Update wrapper: Advanced decorator pattern
def timing_decorator(func):
    @wraps(func)
        import time
        start = time.time()
        result = func(*args, **kwargs)
        elapsed = time.time() - start
        print(f'{func.__name__} took {elapsed:.4f}s')
        return result
@timing_decorator
def slow_operation():
    time.sleep(0.1)
    return 'Done'
slow_operation()  # Prints timing info`,
        tips: [
          'partial(func, arg1) creates a new function with arg1 pre-filled — useful for callbacks',
          'lru_cache requires hashable arguments (no lists/dicts). Convert to tuple if needed',
          'reduce(func, iterable, init) accumulates: result = func(func(func(init, x0), x1), ...)',
          '@wraps in decorators preserves __name__, __doc__ — helps with debugging and documentation',
        ],
        mistake: 'Using @lru_cache with unhashable arguments (lists, dicts). Convert to hashable: @lru_cache works with tuples, strings, frozensets.',
        shorthand: {
          verbose: `from functools import partial, lru_cache, reduce, wraps
from operator import mul, add
def multiply(a, b):
return a * b`,
          concise: `slow_operation()  # Prints timing info`
        }
      },
      {
        id: 'collections-counter-deque', fn: 'collections (Counter, defaultdict, deque, namedtuple)', desc: 'Specialized data structures for counting, defaults, queues, and tuples.',
        category: 'Data Structures', subtitle: 'Efficient alternatives to dict and list for specific use cases',
        signature: 'from collections import Counter, defaultdict, deque, namedtuple',
        descLong: 'collections module provides optimized data structures. Counter counts occurrences, defaultdict avoids KeyError, deque is a fast double-ended queue, namedtuple creates lightweight tuple subclasses with named fields.',
        code: `from collections import Counter, defaultdict, deque, namedtuple
# Counter: Count occurrences
words = ['apple', 'banana', 'apple', 'cherry', 'banana', 'apple']
word_counts = Counter(words)
print(word_counts)  # Counter({'apple': 3, 'banana': 2, 'cherry': 1})
print(word_counts['apple'])   # 3
print(word_counts['orange'])  # 0 (missing keys return 0)
print(word_counts.most_common(2))  # [('apple', 3), ('banana', 2)]
# Count string characters
char_counts = Counter('abracadabra')
print(char_counts)  # Counter({'a': 5, 'b': 2, 'r': 2, 'c': 1, 'd': 1})
# Update counts
word_counts.update(['apple', 'date'])  # Increment counts
print(word_counts)  # apple: 4, date: 1
# Arithmetic with Counter
counter1 = Counter({'a': 3, 'b': 1})
counter2 = Counter({'a': 1, 'b': 2, 'c': 3})
print(counter1 + counter2)  # Counter({'a': 4, 'b': 3, 'c': 3})
print(counter1 - counter2)  # Counter({'a': 2})
print(counter1 & counter2)  # Counter({'a': 1, 'b': 1}) (intersection)
print(counter1 | counter2)  # Counter({'c': 3, 'a': 3, 'b': 2}) (union)

# defaultdict: Avoid KeyError with default values
def_dict = defaultdict(list)  # Default: empty list
def_dict['fruits'].append('apple')
def_dict['fruits'].append('banana')
def_dict['veggies'].append('carrot')
print(dict(def_dict))  # {'fruits': ['apple', 'banana'], 'veggies': ['carrot']}
# Grouping with defaultdict
sentences = ['hello world', 'hello python', 'goodbye world']
words_by_length = defaultdict(list)
for sentence in sentences:
    for word in sentence.split():
        words_by_length[len(word)].append(word)
print(dict(words_by_length))  # {5: ['hello', 'world', 'python'], 7: ['goodbye']}
# defaultdict with int (for counting)
counts = defaultdict(int)
for letter in 'abracadabra':
    counts[letter] += 1
print(dict(counts))  # {'a': 5, 'b': 2, 'r': 2, 'c': 1, 'd': 1}
# deque: Fast double-ended queue
queue = deque([1, 2, 3, 4])
queue.append(5)      # Add to right
queue.appendleft(0)  # Add to left
print(queue)  # deque([0, 1, 2, 3, 4, 5])
value = queue.pop()       # Remove from right → 5
value = queue.popleft()   # Remove from left → 0
print(queue)  # deque([1, 2, 3, 4])
# Rotating
queue.rotate(1)   # Rotate right
print(queue)  # deque([4, 1, 2, 3])
# Fixed-size deque (sliding window)
window = deque(maxlen=3)
for i in range(6):
    window.append(i)
    if len(window) == 3:
        print(list(window))  # [0, 1, 2], [1, 2, 3], [2, 3, 4], [3, 4, 5]
# namedtuple: Lightweight tuple with named fields
Point = namedtuple('Point', ['x', 'y'])
point = Point(1, 2)
print(point.x, point.y)  # 1 2
print(point[0], point[1])  # 1 2 (still indexable)
# Unpack namedtuple
x, y = point
print(x, y)  # 1 2
# Factory for multiple instances
Person = namedtuple('Person', ['name', 'age', 'email'])
people = [
    Person('Alice', 30, 'alice@example.com'),
    Person('Bob', 25, 'bob@example.com'),
    Person('Charlie', 35, 'charlie@example.com')
]
for person in people:
    print(f'{person.name} ({person.age}): {person.email}')
# namedtuple with defaults
Color = namedtuple('Color', ['red', 'green', 'blue'], defaults=[0, 0, 0])
black = Color()
white = Color(255, 255, 255)
print(black)   # Color(red=0, green=0, blue=0)
print(white)   # Color(red=255, green=255, blue=255)
# Convert namedtuple to dict
point = Point(10, 20)
point_dict = point._asdict()
print(point_dict)  # {'x': 10, 'y': 20}
# Replace fields
updated = point._replace(x=5)
print(updated)  # Point(x=5, y=20)`,
          tips: [
          'Counter most_common(n) returns top N items — efficient for finding most frequent',
          'defaultdict avoids try/except or .get() for missing keys — cleaner code',
          'deque with maxlen auto-evicts oldest when full — perfect for sliding windows',
          'namedtuple lightweight than dataclass, no methods — use for simple data containers',
        ],
        mistake: 'Using regular dict when defaultdict would simplify code. defaultdict eliminates if key in dict checks.',
        shorthand: {
          verbose: `result = []
for x in items:
    if x > 0:
        result.append(x)`,
          concise: `result = [x for x in items if x > 0]`
        }
      },
      {
        id: 'context-managers-with', fn: 'Context Managers (with statement)', desc: 'Safely acquire/release resources with __enter__ and __exit__.',
        category: 'Control Flow', subtitle: 'Automatic cleanup of files, locks, connections',
        signature: 'class MyContext:\n    def __enter__(self): ...\n    def __exit__(self, exc_type, exc, tb): ...',
        descLong: 'Context managers (with statement) ensure setup and cleanup code runs. Use for files, database connections, locks, and temporary state changes. Define __enter__ (acquire) and __exit__ (release).',
        code: `import os
# File context manager (most common)
with open('data.txt', 'r') as f:
    content = f.read()
    # File automatically closed after block, even if error occurs
# Multiple resources
with open('input.txt') as infile, open('output.txt', 'w') as outfile:
    for line in infile:
        outfile.write(line.upper())
# Database connection example
class DatabaseConnection:
    def __init__(self, host, port):
        self.host = host
        self.port = port
        self.connected = False
    def __enter__(self):
        print(f'Connecting to {self.host}:{self.port}...')
        self.connected = True
        return self  # Return resource to use in 'as' clause
    def __exit__(self, exc_type, exc_val, exc_tb):
        print('Disconnecting...')
        # Suppress exception if you return True
        if exc_type is not None:
            print(f'Error occurred: {exc_val}')
        return False  # Don't suppress exception
# Usage
with DatabaseConnection('localhost', 5432) as db:
    print(f'Connected: {db.connected}')
    # Do stuff with db
# Lock context manager (thread safety)
from threading import Lock
lock = Lock()
def critical_section():
    with lock:
        # Only one thread at a time enters here
        print('In critical section')
        # do work
    # Lock automatically released
# Timer context manager
import time
class Timer:
    def __init__(self, name=''):
        self.name = name
        self.start = None
        self.start = time.time()
        return self
    def __exit__(self, *args):
        elapsed = time.time() - self.start
        print(f'{self.name} took {elapsed:.4f}s')
with Timer('database query') as timer:
    time.sleep(0.1)  # Simulate work
# Temporary directory cleanup
from tempfile import TemporaryDirectory
with TemporaryDirectory() as tmpdir:
    print(f'Working in {tmpdir}')
    # Create files here
# Directory automatically deleted after block
# Suppress exceptions
from contextlib import suppress
with suppress(FileNotFoundError):
    import os
    os.remove('nonexistent.txt')  # No error raised
# Redirect stdout
from contextlib import redirect_stdout
import io
output = io.StringIO()
with redirect_stdout(output):
    print('This is redirected')
result = output.getvalue()
print(result)  # 'This is redirected\\n'
# contextlib.contextmanager decorator (simpler syntax)
from contextlib import contextmanager

@contextmanager
def my_context(name):
    print(f'Entering {name}')
    try:
        yield f'Resource for {name}'
    finally:
        print(f'Exiting {name}')
with my_context('my_task') as resource:
    print(f'Using {resource}')
# Nested contexts with cleanup
def database_transaction():
    conn = get_connection()
    print('Transaction started')
        yield conn
    except Exception as e:
        print(f'Rolling back: {e}')
        conn.rollback()
        raise
    else:
        print('Committing')
        conn.commit()
        conn.close()
with database_transaction() as conn:
    cursor = conn.cursor()
    cursor.execute('INSERT ...')
# ExitStack: Manage multiple contexts dynamically
from contextlib import ExitStack
with ExitStack() as stack:
    files = [stack.enter_context(open(f'file{i}.txt')) for i in range(3)]
    # All files opened and will be closed when exiting block
    for f in files:
        print(f.read())`,
        tips: [
          '__exit__ receives exception info (type, value, traceback) — return True to suppress',
          'Use @contextmanager decorator for simple context managers — often cleaner than class',
          'ExitStack manages multiple resources dynamically — perfect for variable number of files',
          'finally in context manager always runs — use for guaranteed cleanup',
        ],
        mistake: 'Forgetting to use with statement. Always use with for file/connection handling — don\'t manually call __enter__/__exit__.',
        shorthand: {
          verbose: `result = []
for x in items:
    if x > 0:
        result.append(x)`,
          concise: `result = [x for x in items if x > 0]`
        }
      },
      {
        id: 'itertools-module', fn: 'itertools (Combinations, Permutations, Chain)', desc: 'Memory-efficient iterators for combinatorics and chaining.',
        category: 'Iteration', subtitle: 'Lazy sequences without creating full lists',
        signature: 'from itertools import combinations, permutations, chain, groupby, islice',
        descLong: 'itertools provides lazy iterators for combinations, permutations, chaining, grouping, and slicing. Memory-efficient because they generate values on-the-fly, not all at once.',
        code: `from itertools import chain, product, combinations, permutations
from itertools import groupby, islice, repeat, cycle
# Combinations: all unordered subsets
items = ['a', 'b', 'c', 'd']
combos = combinations(items, 2)
print(list(combos))  # [('a', 'b'), ('a', 'c'), ('a', 'd'), ('b', 'c'), ('b', 'd'), ('c', 'd')]
# Useful for finding pairs
numbers = [1, 2, 3, 4, 5]
pairs = combinations(numbers, 2)
print(list(pairs))  # All (n choose 2) pairs
# Permutations: all ordered arrangements
perms = permutations(['a', 'b', 'c'], 2)
print(list(perms))  # [('a', 'b'), ('a', 'c'), ('b', 'a'), ('b', 'c'), ('c', 'a'), ('c', 'b')]
# All arrangements of 3 items (3! = 6 permutations)
all_perms = permutations(['x', 'y', 'z'])
print(list(all_perms))  # 6 permutations
# chain: Flatten multiple iterables
iter1 = [1, 2, 3]
iter2 = [4, 5, 6]
iter3 = [7, 8, 9]
chained = chain(iter1, iter2, iter3)
print(list(chained))  # [1, 2, 3, 4, 5, 6, 7, 8, 9]
# More efficient than + operator
result = list(chain(['a', 'b'], ['c', 'd'], ['e', 'f']))
print(result)  # ['a', 'b', 'c', 'd', 'e', 'f']
# chain.from_iterable: Flatten list of lists
lists = [[1, 2], [3, 4], [5, 6]]
flat = chain.from_iterable(lists)
print(list(flat))  # [1, 2, 3, 4, 5, 6]
# islice: Lazy slicing (like list slicing but for iterators)
numbers = range(10)
subset = islice(numbers, 2, 7)  # From index 2 to 7
print(list(subset))  # [2, 3, 4, 5, 6]
# Take first N
first_five = islice(range(100), 5)
print(list(first_five))  # [0, 1, 2, 3, 4]
# Every Nth item
every_third = islice(range(10), 0, None, 3)
print(list(every_third))  # [0, 3, 6, 9]
# groupby: Group consecutive equal items
data = [1, 1, 1, 2, 2, 3, 1, 1]
grouped = groupby(data)
for key, group in grouped:
    print(f'{key}: {list(group)}')
    # 1: [1, 1, 1]
    # 2: [2, 2]
    # 3: [3]
    # 1: [1, 1]
# Group words by first letter
words = ['apple', 'apricot', 'banana', 'blueberry', 'cherry']
sorted_words = sorted(words)
for letter, group in groupby(sorted_words, key=lambda w: w[0]):
    print(f'{letter}: {list(group)}')
    # a: ['apple', 'apricot']
    # b: ['banana', 'blueberry']
    # c: ['cherry']
# repeat: Repeat value infinitely
repeated = repeat(42, 3)  # Repeat 42 three times
print(list(repeated))  # [42, 42, 42]
# Infinite repeat
infinite = repeat('x')
first_ten = islice(infinite, 10)
print(list(first_ten))  # ['x', 'x', 'x', ...]
# cycle: Cycle through iterable infinitely
colors = cycle(['red', 'green', 'blue'])
first_seven = islice(colors, 7)
print(list(first_seven))  # ['red', 'green', 'blue', 'red', 'green', 'blue', 'red']
# product: Cartesian product
colors = ['red', 'blue']
sizes = ['S', 'M', 'L']
items = product(colors, sizes)
print(list(items))
# [('red', 'S'), ('red', 'M'), ('red', 'L'), ('blue', 'S'), ('blue', 'M'), ('blue', 'L')]

# Equivalent to nested loops
for color in colors:
    for size in sizes:
        print(f'{color}-{size}')
# Memory efficiency
print('Combinations object:', combinations(range(100), 2))  # Iterator, not list
# Same as: sum(1 for _ in combinations(range(100), 2))  # 4950 (memory-efficient)
# Practical example: Find all unique pairs and their sums
numbers = [1, 2, 3, 4]
pairs_with_sum = [(a, b, a+b) for a, b in combinations(numbers, 2)]
print(pairs_with_sum)
# [(1, 2, 3), (1, 3, 4), (1, 4, 5), (2, 3, 5), (2, 4, 6), (3, 4, 7)]`,
          tips: [
          'combinations/permutations return iterators (lazy) — don\'t convert to list unless needed',
          'chain.from_iterable() flattens nested iterables without creating intermediate lists',
          'groupby requires data sorted by key — sort first if needed',
          'islice + repeat/cycle create infinite lazy sequences — process with islice or list comprehension',
        ],
        mistake: 'Calling list() immediately on itertools results for large datasets. Use iterators directly in loops when possible to save memory.',
        shorthand: {
          verbose: `result = {}
for k, v in pairs:
    result[k] = v`,
          concise: `result = {k: v for k, v in pairs}`
        }
      },
      {
        id: 're-module-regex', fn: 're Module (Regular Expressions)', desc: 'Pattern matching and text manipulation with regex.',
        category: 'Text Processing', subtitle: 'Search, split, and replace text with patterns',
        signature: 'import re\nre.search(pattern, string)\nre.match(pattern, string)\nre.findall(pattern, string)',
        descLong: 're module provides regex functionality for pattern matching, extraction, substitution, and splitting. Compile patterns for reuse, use groups for extraction, leverage named groups for clarity.',
        code: `import re
# Basic search (returns Match object or None)
text = 'The quick brown fox jumps over the lazy dog'
if re.search(r'fox', text):
    print('Found fox!')
# match vs search
# match: from start of string
# search: anywhere in string
print(re.match(r'The', text))      # Match (starts with 'The')
print(re.match(r'quick', text))    # None (doesn't start with 'quick')
print(re.search(r'quick', text))   # Match (found 'quick' anywhere)
# Compile for reuse (faster)
phone_pattern = re.compile(r'\\d{3}-\\d{3}-\\d{4}')
phones = ['123-456-7890', '999-888-7777', '555-123-4567']
for phone in phones:
    if phone_pattern.match(phone):
        print(f'Valid phone: {phone}')
# findall: Find all matches
text = 'Emails: alice@example.com, bob@test.org, charlie@demo.net'
emails = re.findall(r'[\\w.-]+@[\\w.-]+', text)
print(emails)  # ['alice@example.com', 'bob@test.org', 'charlie@demo.net']
# Extract numbers
text = 'Prices: $10, $25, $50, $100'
prices = re.findall(r'\\$?\\d+', text)
print(prices)  # ['10', '25', '50', '100']
# Groups: Extract parts of a match
pattern = r'(\\w+)@([\\w.]+)'  # (user) @ (domain)
match = re.search(pattern, 'alice@example.com')
print(match.group(0))   # Full match: 'alice@example.com'
print(match.group(1))   # Group 1: 'alice'
print(match.group(2))   # Group 2: 'example.com'
# Named groups: More readable
pattern = r'(?P<user>\\w+)@(?P<domain>[\\w.]+)'
print(match.group('user'))     # 'alice'
print(match.group('domain'))   # 'example.com'
print(match.groupdict())       # {'user': 'alice', 'domain': 'example.com'}
# finditer: Iterate matches with details
text = 'Meetings: 2pm (Office), 3pm (Remote), 4:30pm (Lab)'
pattern = r'(\\d{1,2}):?(\\d{2})?pm \\(([^)]+)\\)'
for match in re.finditer(pattern, text):
    time_str = f'{match.group(1)}:{match.group(2) or "00"}'
    location = match.group(3)
    print(f'{time_str} @ {location}')
    # 2:00 @ Office
    # 3:00 @ Remote
    # 4:30 @ Lab
# sub: Replace matches
text = 'Hello World'
result = re.sub(r'World', 'Python', text)
print(result)  # 'Hello Python'
# Replace with groups
text = 'Name: John, Age: 30'
result = re.sub(r'(\\w+): (\\w+)', r'\\2=\\1', text)
print(result)  # 'John=Name, 30=Age'
# Replace with function
def uppercase_match(match):
    return match.group(0).upper()
text = 'hello world'
result = re.sub(r'\\w+', uppercase_match, text)
print(result)  # 'HELLO WORLD'
# split: Split by pattern
text = 'apple, banana; orange:grape'
parts = re.split(r'[,;:]', text)
print(parts)  # ['apple', ' banana', ' orange', 'grape']
# Capture groups in split
text = 'a1b2c3d'
parts = re.split(r'(\\d)', text)
print(parts)  # ['a', '1', 'b', '2', 'c', '3', 'd']
# Flags
text = 'HELLO hello Hello'
# Case-insensitive search
matches = re.findall(r'hello', text, re.IGNORECASE)
print(len(matches))  # 3
# Multiline mode (^ and $ match line boundaries)
text = '''Line 1
Line 2
Line 3'''
lines = re.findall(r'^Line.*', text, re.MULTILINE)
print(lines)  # ['Line 1', 'Line 2', 'Line 3']
# VERBOSE: Readable regex with comments
pattern = re.compile(r'''
    (\\d{1,2})/       # Day
    (\\d{1,2})/       # Month
    (\\d{4})          # Year
''', re.VERBOSE)
match = pattern.search('3/16/2026')
print(match.groups())  # ('03', '16', '2026')
# Lookahead/Lookbehind (advanced)
text = 'price: $100 and cost: $50'
amounts = re.findall(r'(?<=\\$)\\d+', text)  # Positive lookbehind
print(amounts)  # ['100', '50']`,
        tips: [
          'Compile complex patterns once: pattern = re.compile(...), then reuse',
          'Use raw strings: r\'...\\d...\' not \'...\\\\d...\' (backslash escaping cleaner)',
          'Named groups (?P<name>...) make patterns self-documenting',
          'Test regex: use regex101.com or regexpal.com before using in code',
        ],
        mistake: 'Not using raw strings (r\'...\') — backslashes need escaping in regular strings. Always use r\'...\' for regex patterns.',
        shorthand: {
          verbose: `result = []
for x in items:
    if x > 0:
        result.append(x)`,
          concise: `result = [x for x in items if x > 0]`
        }
      },
      {
        id: 'logging-module', fn: 'logging Module', desc: 'Configure and output structured logs with levels and handlers.',
        category: 'Debugging', subtitle: 'Replace print() with configurable logging',
        signature: 'import logging\nlogging.basicConfig(...)\nlogger.info(...)\nlogger.error(...)',
        descLong: 'logging module provides levels (DEBUG, INFO, WARNING, ERROR, CRITICAL), handlers (file, stream, email), and formatters. More flexible than print() for production code.',
        code: `import logging
from logging.handlers import RotatingFileHandler

# Basic setup
logging.basicConfig(
    level=logging.DEBUG,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
)
logger = logging.getLogger(__name__)
logger.debug('Debug message')
logger.info('Info message')
logger.warning('Warning message')
logger.error('Error message')
logger.critical('Critical message')
# Output:
# 2026-03-16 12:34:56,789 - __main__ - DEBUG - Debug message
# 2026-03-16 12:34:56,790 - __main__ - INFO - Info message
# ...
# Log levels (only messages >= level are logged)
logging.basicConfig(level=logging.WARNING)
logger.debug('Not shown')
logger.info('Not shown')
logger.warning('Shown!')
logger.error('Shown!')
# Logger hierarchy (by module)
logger1 = logging.getLogger('myapp.database')
logger2 = logging.getLogger('myapp.api')
logger3 = logging.getLogger('myapp')  # Parent
# All share same handlers (set on parent)
logging.basicConfig(format='%(name)s: %(message)s')
logger1.info('Database info')
logger2.info('API info')
logger3.info('App info')
# File handler (write to file)
handler = logging.FileHandler('app.log')
handler.setLevel(logging.INFO)
formatter = logging.Formatter('%(asctime)s - %(levelname)s - %(message)s')
handler.setFormatter(formatter)
logger.addHandler(handler)
# Rotating file handler (create new files when size limit reached)
rotating_handler = RotatingFileHandler(
    'app.log',
    maxBytes=1000000,  # 1 MB
    backupCount=5      # Keep 5 backup files
rotating_handler.setFormatter(formatter)
logger.addHandler(rotating_handler)
# Log to file and console
console_handler = logging.StreamHandler()
console_handler.setLevel(logging.WARNING)
logger.addHandler(console_handler)
# Exception logging
try:
    result = 1 / 0
except ZeroDivisionError:
    logger.exception('Math error occurred')  # Includes traceback
# Log variables
user = 'Alice'
age = 30
logger.info(f'User {user} is {age} years old')
# Structured logging with extra fields
logger.info('Event', extra={'user_id': 123, 'action': 'login'})
# Lazy string formatting (efficient)
logger.debug('Value: %s', expensive_calculation())  # Only called if DEBUG is enabled
# Disable certain loggers (third-party libraries)
logging.getLogger('urllib3').setLevel(logging.WARNING)
logging.getLogger('requests').setLevel(logging.WARNING)
# Configuration from dict
config = {
    'version': 1,
    'formatters': {
        'standard': {
            'format': '%(asctime)s - %(name)s - %(levelname)s - %(message)s'
    },
    'handlers': {
        'console': {
            'class': 'logging.StreamHandler',
            'level': 'INFO',
            'formatter': 'standard'
        },
        'file': {
            'class': 'logging.FileHandler',
            'level': 'DEBUG',
            'formatter': 'standard',
            'filename': 'debug.log'
    'root': {
        'level': 'DEBUG',
        'handlers': ['console', 'file']
    }
}
import logging.config
logging.config.dictConfig(config)
logger.debug('Debug to file only')
logger.info('Info to console and file')`,
          tips: [
          'Use logger per module: logger = logging.getLogger(__name__) — hierarchy makes filtering easy',
          'Avoid logging sensitive data (passwords, tokens) — set level to WARNING in production',
          'File rotation prevents massive log files — RotatingFileHandler auto-manages backups',
          'Use lazy formatting: logger.info("x=%s", var) only formats if level enabled',
        ],
        mistake: 'Using print() in production code. Replace with logging — allows runtime filtering, file output, and structured logging.',
        shorthand: {
          verbose: `result = []
for x in items:
    if x > 0:
        result.append(x)`,
          concise: `result = [x for x in items if x > 0]`
        }
      },

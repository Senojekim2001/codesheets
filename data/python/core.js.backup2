        id: 'functools', fn: 'functools', desc: 'Higher-order function utilities — caching, partial application, ordering.',
        category: 'Standard Library', subtitle: 'lru_cache, partial, reduce, wraps, total_ordering',
        signature: '@lru_cache(maxsize=128) | partial(fn, *args) | reduce(fn, it)',
        descLong: 'functools provides tools for working with higher-order functions. lru_cache memoizes results — one of the easiest performance wins in Python. partial() fixes arguments. total_ordering generates comparison methods from just two.',
        code: `import functools

# lru_cache — memoize results:
@functools.lru_cache(maxsize=256)
def fib(n: int) -> int:
    return n if n < 2 else fib(n-1) + fib(n-2)

fib(100)             # instant
fib.cache_info()     # CacheInfo(hits=98, misses=101, ...)
fib.cache_clear()

@functools.cache     # Python 3.9+ — unbounded cache, cleaner
def expensive(n): return n**2

# partial — fix arguments:
from functools import partial
def power(base, exp): return base ** exp

square = partial(power, exp=2)
cube   = partial(power, exp=3)
square(5)    # 25

# reduce — fold a binary function:
from functools import reduce
reduce(lambda acc, x: acc + x, [1,2,3,4,5])  # 15
reduce(lambda acc, x: acc * x, [1,2,3,4,5])  # 120

# wraps — preserve function metadata in decorators:
def my_decorator(fn):
    @functools.wraps(fn)   # fn.__name__ and __doc__ preserved
    def wrapper(*args, **kwargs):
        return fn(*args, **kwargs)
    return wrapper

# total_ordering — fill in comparison methods:
from functools import total_ordering

@total_ordering
class Version:
    def __init__(self, major, minor):
        self.major, self.minor = major, minor
    def __eq__(self, other):
        return (self.major, self.minor) == (other.major, other.minor)
    def __lt__(self, other):
        return (self.major, self.minor) < (other.major, other.minor)
    # >, >=, <= generated automatically`,
        tips: [
          '`@functools.cache` (3.9+) is the simplest memoization — no `maxsize` argument needed',
          '`partial()` is cleaner than a lambda for simple argument fixing when you need a name',
          '`@total_ordering` requires `__eq__` + one comparison method — generates the other three',
          '`@lru_cache` on a method with `self` caches the instance — use `@cached_property` for instance-level caching instead',
        ],
        mistake: '`@lru_cache` on an instance method caches all calls including `self`, which prevents garbage collection of the instance. Cache only module-level functions, or use `@cached_property`.',
        shorthand: {
          verbose: `def fib(n):
    if n < 2: return n
    return fib(n-1) + fib(n-2)
fib(100)  # Slow without cache`,
          concise: `@functools.lru_cache(maxsize=128)
def fib(n):
    return n if n < 2 else fib(n-1) + fib(n-2)
fib(100)  # Instant with caching`
        }
